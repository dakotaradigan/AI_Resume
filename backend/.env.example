# Anthropic (required for chat responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Primary model: answers complex/thoughtful questions and all JD fit analyses.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=2048
# Model routing (optional - defaults provided). Simple factual questions are
# answered by ANTHROPIC_MODEL_SIMPLE; ANTHROPIC_ROUTER_MODEL is the small
# classifier that decides. Complex questions stay on ANTHROPIC_MODEL.
# ANTHROPIC_MODEL_SIMPLE=claude-sonnet-5
# ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001

# RAG retrieval (optional; set false to use compact static resume context)
USE_RAG=true

# OpenAI (required for RAG embeddings when USE_RAG=true)
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant configuration (required when USE_RAG=true)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_here  # Only needed for Qdrant Cloud

# Retrieval evals require a separate non-production Qdrant target. The eval
# runner never falls back to QDRANT_URL/QDRANT_API_KEY.
# EVAL_QDRANT_URL=http://localhost:6334
# EVAL_QDRANT_API_KEY=your_eval_qdrant_api_key_here

# Data directory (leave default unless you move /data)
# DATA_DIR=/absolute/path/to/data

# Application Settings
ENVIRONMENT=development
# NOTE: Do NOT run the app with a framework debug/traceback page enabled in any
# deployed environment. Starlette's debug traceback renders frame-local variables,
# which would expose secrets (e.g. ANTHROPIC_API_KEY) to anyone who triggers an error.

# Scalability Settings (optional - defaults provided)
# RATE_LIMIT_REQUESTS_PER_MINUTE=20  # Max requests per session per minute
# SESSION_MAX_AGE_SECONDS=3600  # 1 hour - auto-cleanup old sessions
# API_TIMEOUT_SECONDS=30.0  # Anthropic API timeout
# TRUST_PROXY_HEADERS=false  # Set true behind Railway so the real client IP is
#   read from X-Forwarded-For (right-most entry). REQUIRED for PER_IP_DAILY_LIMIT
#   to take effect; verify your proxy appends the client IP and doesn't pass a
#   client-spoofable header through.
# PER_IP_DAILY_LIMIT=40  # Hard cap on token-spending requests (chat + JD) per
#   client IP per day. Survives cookie rotation, so no single IP can drain the
#   global budget; password-unlocked visitors bypass it. 0 disables. Inactive
#   unless TRUST_PROXY_HEADERS=true.
# REDIS_URL=redis://default:password@host:port  # Railway Redis for shared sessions and limits

# Chat Limit Protection
# CHAT_PASSWORD can be found on Dakota's resume - please reach out to him on LinkedIn if you have questions or would like the password
CHAT_PASSWORD=your_chat_password_here
# FREE_CHAT_LIMIT=2  # Number of exchanges before requiring password
# DAILY_CONVERSATION_LIMIT=200  # Global model-call budget per day across ALL visitors (token spend ceiling)

# JD Fit Analysis
# MAX_JD_CHARS=15000  # Max pasted job-description length
# JD_DAILY_LIMIT=1  # Free fit analyses per visitor per day; the chat password unlocks unlimited (screening briefs are free)

# Visitor identity & analytics privacy
# VISITOR_COOKIE_NAME=resume_assistant_visitor_id
# VISITOR_TTL_SECONDS=2592000  # 30 days
# SESSION_HASH_SECRET=set_a_stable_random_hex_in_production  # keeps analytics ids stable across restarts
