# Anthropic (required for chat responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-5-20251101
ANTHROPIC_MAX_TOKENS=2048
# Model routing (optional - defaults provided). Simple factual questions are
# answered by ANTHROPIC_MODEL_SIMPLE; ANTHROPIC_ROUTER_MODEL is the small
# classifier that decides. Complex questions stay on ANTHROPIC_MODEL.
# ANTHROPIC_MODEL_SIMPLE=claude-sonnet-5
# ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001

# OpenAI (required for RAG embeddings in Phase 3)
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Configuration (Phase 3 - RAG Pipeline)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_here  # Only needed for Qdrant Cloud

# Data directory (leave default unless you move /data)
# DATA_DIR=/absolute/path/to/data

# Application Settings
ENVIRONMENT=development
# NOTE: Do NOT run the app with a framework debug/traceback page enabled in any
# deployed environment. Starlette's debug traceback renders frame-local variables,
# which would expose secrets (e.g. ANTHROPIC_API_KEY) to anyone who triggers an error.

# Scalability Settings (optional - defaults provided)
# RATE_LIMIT_REQUESTS_PER_MINUTE=20  # Max requests per session per minute
# SESSION_MAX_AGE_SECONDS=3600  # 1 hour - auto-cleanup old sessions
# API_TIMEOUT_SECONDS=30.0  # Anthropic API timeout
# TRUST_PROXY_HEADERS=false  # Enable only if your proxy safely overwrites X-Forwarded-For
# REDIS_URL=redis://default:password@host:port  # Railway Redis for shared sessions and limits

# Chat Limit Protection
# CHAT_PASSWORD can be found on Dakota's resume - please reach out to him on LinkedIn if you have questions or would like the password
CHAT_PASSWORD=your_chat_password_here
# FREE_CHAT_LIMIT=2  # Number of exchanges before requiring password
